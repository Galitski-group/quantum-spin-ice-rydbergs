@article{wilsonConfinementQuarks1974,
  author =        {Wilson, Kenneth G.},
  journal =       {Phys. Rev. D},
  month =         oct,
  number =        {8},
  pages =         {2445--2459},
  publisher =     {{American Physical Society}},
  title =         {Confinement of Quarks},
  volume =        {10},
  year =          {1974},
  abstract =      {A mechanism for total confinement of quarks, similar
                   to that of Schwinger, is defined which requires the
                   existence of Abelian or non-Abelian gauge fields. It
                   is shown how to quantize a gauge field theory on a
                   discrete lattice in Euclidean space-time, preserving
                   exact gauge invariance and treating the gauge fields
                   as angular variables (which makes a gauge-fixing term
                   unnecessary). The lattice gauge theory has a
                   computable strong-coupling limit; in this limit the
                   binding mechanism applies and there are no free
                   quarks. There is unfortunately no Lorentz (or
                   Euclidean) invariance in the strong-coupling limit.
                   The strong-coupling expansion involves sums over all
                   quark paths and sums over all surfaces (on the
                   lattice) joining quark paths. This structure is
                   reminiscent of relativistic string models of
                   hadrons.},
  doi =           {10.1103/PhysRevD.10.2445},
  url =           {https://link.aps.org/doi/10.1103/PhysRevD.10.2445},
}

