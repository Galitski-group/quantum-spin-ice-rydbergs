@article{gu_symmetry-protected_2014,
  title = {Symmetry-Protected Topological Orders for Interacting Fermions: {{Fermionic}} Topological Nonlinear \$\textbackslash ensuremath\{\textbackslash sigma\}\$ Models and a Special Group Supercohomology Theory},
