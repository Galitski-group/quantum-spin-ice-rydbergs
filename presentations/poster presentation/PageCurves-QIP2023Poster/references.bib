@article{wang_symmetric_2018,
  title = {Symmetric {{Gapped Interfaces}} of {{SPT}} and {{SET States}}: {{Systematic Constructions}}},
  shorttitle = {Symmetric {{Gapped Interfaces}} of {{SPT}} and {{SET States}}},
  author = {Wang, Juven and Wen, Xiao-Gang and Witten, Edward},
