}

@article{tsui_lattice_2020,
  title = {Lattice Models That Realize \$\{\textbackslash mathbb\{\vphantom{\}\}}{{Z}}\vphantom\{\}\vphantom\{\}\_\{n\}\$-1 Symmetry-Protected Topological States for Even \$n\$},
