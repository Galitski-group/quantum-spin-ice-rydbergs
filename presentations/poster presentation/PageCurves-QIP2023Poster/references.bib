@article{fechisin_categorical_nodate,
  title = {Categorical Symmetry Protection: Microscopics, Stabilizers, and Cluster States},
  author = {Fechisin, Christopher and Tantivasadakarn, Nathanan and Albert, Victor V.},
  abstract = {Despite growing interest in beyond-group symmetries in quantum condensed matter systems, there are relatively few microscopic lattice models explicitly realizing these symmetries, and many phenomena have yet to be generalized at the microscopic level. In this work, we show that the algebraic cluster state introduced in \textbackslash href\{http://doi.org/10.1088/1367-2630/17/2/023029\}\{Brell, New Journal of Physics \textbackslash textbf\{17\}, 023029 (2015)\} is a symmetry protected topological (SPT) state with \$G\textbackslash times \textbackslash rep G\$ symmetry. We introduce a generalized Pauli stabilizer Hamiltonian which has the algebraic cluster state as its ground state and study the generalization of several characteristic signatures of SPT order: protected edge modes, algebraic structure under stacking, and topological response. In the final section, we discuss how the algebraic cluster state can be used as a universal resource for measurement-based quantum computation (MBQC).}
}

